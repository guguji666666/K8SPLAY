# Pod Cleaner Environment Configuration
# Copy this file to .env and fill in your values

# Required: Bark push service URL
# Get your device key from your Bark app or server
# Example: https://bark.day.app/ABC123DEF456/push
BARK_BASE_URL=""

# Optional: Enable/disable notifications (default: true)
BARK_ENABLED="true"

# Optional: Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Optional: Run interval in seconds (default: 600 = 10 minutes)
# RUN_INTERVAL_SECONDS="600"

# ============================================================
# Recovery Verification Configuration (NEW FEATURE)
# ============================================================

# Optional: Enable/disable recovery verification (default: true)
RECOVERY_CHECK_ENABLED="true"

# Optional: Wait time for new pod creation in seconds (default: 120)
RECOVERY_WAIT_SECONDS="120"

# Optional: Maximum retry attempts before escalation (default: 3)
RECOVERY_MAX_ATTEMPTS="3"

# Optional: Check interval when waiting for new pod (default: 10)
RECOVERY_CHECK_INTERVAL="10"

# Optional: State file path for persistence (default: /var/lib/pod-cleaner/state.json)
PERSISTENCE_FILE="/var/lib/pod-cleaner/state.json"

# Optional: Cleanup old entries after hours (default: 24)
PERSISTENCE_MAX_AGE_HOURS="24"
